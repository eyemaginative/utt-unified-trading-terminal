# UTT example environment configuration
# Copy to `.env` and fill in real values locally.
# NEVER commit `.env`.

# App
UTT_APP_ENV=development
UTT_APP_PORT=3000
UTT_LOG_LEVEL=info

# Auth / session
UTT_SESSION_SECRET=change_me_local_only
UTT_JWT_ISSUER=utt-local
UTT_JWT_AUDIENCE=utt-users

# Trading mode safety
UTT_TRADING_MODE=paper
UTT_MAX_ORDER_NOTIONAL_USD=1000
UTT_DAILY_LOSS_LIMIT_USD=250

# Market data
UTT_MARKET_DATA_PROVIDER=example-provider
UTT_MARKET_DATA_REST_URL=https://api.example.com
UTT_MARKET_DATA_WS_URL=wss://stream.example.com

# Broker / exchange connectivity
UTT_BROKER_NAME=example-broker
UTT_BROKER_API_BASE_URL=https://broker.example.com
UTT_BROKER_ACCOUNT_ID=replace-with-non-secret-account-id

# Secrets (placeholders only; set real values only in local .env or secret manager)
UTT_BROKER_API_KEY=replace-me
UTT_BROKER_API_SECRET=replace-me
UTT_WEBHOOK_SIGNING_SECRET=replace-me

# Storage
UTT_DATABASE_URL=postgresql://user:password@localhost:5432/utt
UTT_REDIS_URL=redis://localhost:6379

# Feature flags
UTT_ENABLE_LIVE_TRADING=false
UTT_ENABLE_EXPERIMENTAL_FEATURES=false
