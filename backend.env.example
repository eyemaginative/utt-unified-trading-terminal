# UTT backend env example
#
# Copy this file to a private location outside the repository, for example:
#   C:\path\to\utt-secrets\backend.env
#
# Then point backend/.env at it with:
#   UTT_ENV_PATH=C:\path\to\utt-secrets\backend.env
#
# Do not commit real API keys, seed phrases, wallet addresses, private key paths,
# database files, or machine-specific private paths. Venue API/RPC keys should be
# saved through Profile -> API Keys when supported.

APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

UTT_VAULT_USERNAME=<your-ui-username>
UTT_AUTH_DISABLE=0
UTT_AUTH_DB=1
# UTT_KMS_MASTER_KEY
# Master secret used to encrypt/decrypt Profile → API Key Vault secrets in the local SQLite DB.
# REQUIRED if you use the API Key Vault (vault secrets become unreadable if this changes).
# Set this once and keep it stable (store outside the repo; do NOT commit).
UTT_KMS_MASTER_KEY=
UTT_REALIZED_FIELDS_V1=1

# SQLite path (relative to backend/)
SQLITE_PATH=C:/path/to/utt-data/app.db

# DRY RUN mode: if true, adapters will not place/cancel real orders
DRY_RUN=true

COINBASE_TOO_MANY_ERRORS_COOLDOWN_S=600
COINBASE_ALLOW_TRANSFER_MUTATIONS=0
COINBASE_TRANSFERS_FALLBACK_TO_TRADE_KEY=1
COINBASE_TRANSFERS_PREFER_V2=1
COINBASE_TRANSFERS_FORCE_V2=1
COINBASE_V2_TX_DEBUG=1
COINBASE_V2_KEEP_DEBUG=1
COINBASE_V2_TX_MAX_PAGES=0
COINBASE_V2_USE_KIND_ENDPOINTS=1
COINBASE_V2_RETRY_500=0
COINBASE_V2_RETRY_500_SLEEP=0
COINBASE_V2_KIND_MAX_PAGES=200
COINBASE_V2_KIND_PAGE_LIMIT=100
COINBASE_V2_INCLUDE_FIAT=0

ROBINHOOD_CRYPTO_BASE_URL=https://trading.robinhood.com
ROBINHOOD_ENABLED=true

DEX_TRADE_ENABLED=true
DEX_TRADE_BASE_URL=https://api.dex-trade.com
DEX_TRADE_SOCKET_BASE_URL=https://socket.dex-trade.com

CRYPTOCOM_EXCHANGE_BASE_URL=https://api.crypto.com/exchange/v1
CRYPTOCOM_INCLUDE_ORDER_HISTORY=1
CRYPTOCOM_DEBUG_ORDERS=1
CRYPTOCOM_ORDER_HISTORY_BYPASS_CACHE=1
CRYPTOCOM_OPEN_ORDERS_CACHE_TTL_S=0
CRYPTOCOM_ORDER_HISTORY_CACHE_TTL_S=0
CRYPTOCOM_ORDER_HISTORY_SCAN_ALL=1
CRYPTOCOM_ORDER_HISTORY_MIN_ROWS=20
CRYPTOCOM_ORDER_HISTORY_MAX_CALLS_PER_REFRESH=20
CRYPTOCOM_ORDER_HISTORY_MAX_INSTRUMENTS_PER_REFRESH=40
CRYPTOCOM_ORDER_HISTORY_LOOKBACK_MAX_MS=15552000000
CRYPTOCOM_ORDER_HISTORY_LOOKBACK_MS=7776000000
CRYPTOCOM_TRADES_LOOKBACK_MS=7776000000
CRYPTOCOM_TRY_ADV_HISTORY=0
CRYPTOCOM_USE_ADVANCED=0

UTT_JUP_SWAP_URL=https://api.jup.ag/swap/v1/swap
UTT_JUP_QUOTE_URL=https://api.jup.ag/swap/v1/quote
UTT_JUP_TIMEOUT_S=10

UTT_HYDRATION_RPC_PROVIDER=dwellir
UTT_HYDRATION_RPC_URL_TEMPLATE=https://api-hydration.n.dwellir.com/{api_key}
UTT_HYDRATION_WS_URL_TEMPLATE=wss://api-hydration.n.dwellir.com/{api_key}
UTT_HYDRATION_RPC_URL=

UTT_HYDRATION_ENABLE_ROUTER_QUOTES=0
UTT_HYDRATION_ENABLE_SWAP_TX=1
UTT_HYDRATION_ENABLE_EXACT_BUY=1

UTT_HYDRATION_ENABLE_MANUAL_POOL_FALLBACK=1
UTT_HYDRATION_MANUAL_POOL_LIVE_RESERVES=1

UTT_HYDRATION_ENABLE_EXTERNAL_USD_PRICES=1
UTT_HYDRATION_EXTERNAL_USD_PRICE_SOURCE=coingecko
UTT_HYDRATION_ENABLE_SDK_PRICE_CACHE=1
UTT_HYDRATION_PRICE_CACHE_USE_SDK_FALLBACK=0
UTT_HYDRATION_PRICE_CACHE_TTL_S=300
UTT_HYDRATION_PRICE_CACHE_ERROR_BACKOFF_S=600
UTT_HYDRATION_EXTERNAL_USD_PRICE_TIMEOUT_S=5

UTT_HYDRATION_HELPER_STEP_TIMEOUT_S=30

ARMED=false
UTT_ORDERBOOK_TTL_SECONDS=2
UTT_ORDERBOOK_TIMEOUT_SECONDS=6
UTT_ORDERBOOK_GLOBAL_MAX_CONCURRENCY=8
UTT_ORDERBOOK_VENUE_MAX_CONCURRENCY=3
UTT_RATE_COOLDOWN_SECONDS=45
UTT_ORDERBOOK_NEG_PAIR_TTL_SECONDS=120
UTT_ORDERBOOK_NEG_RATE_TTL_SECONDS=60
BAL_MAX_PRICE_ASSETS=500
UTT_MAX_PRICE_ASSETS_PER_CALL=500
UTT_PRICING_FALLBACK_VENUES=coinbase,kraken,gemini
UTT_BALANCE_PRICING_VENUES=coinbase,kraken,gemini
